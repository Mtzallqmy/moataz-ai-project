  "messages": [
    {
      "id": "msg-1",
      "conversationId": "conv-1",
      "role": "user",
      "content": "How does the Moataz AI Gateway save costs on large volume model requests?",
      "tokenCount": 15,
      "cost": 0.000001,
      "createdAt": "2026-07-01T17:20:18.318Z"
    },
    {
      "id": "msg-2",
      "conversationId": "conv-1",
      "role": "assistant",
      "content": "Moataz AI reduces costs using semantic caching, intelligent fallback, routing requests dynamically to cheaper models (such as Gemini 3.5 Flash) when high reasoning (like Claude Sonnet) isn't triggered, and utilizing real-time token tracking to prevent over-budget calls.",
      "tokenCount": 45,
      "cost": 0.000013,
      "createdAt": "2026-07-01T17:20:23.318Z"
    }
  ],
