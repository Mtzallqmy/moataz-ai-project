{
  "version": 2,
  "buildCommand": "npm run build && npm run prisma:migrate",
  "installCommand": "npm install",
  "env": {
    "NODE_ENV": "production"
  },
  "builds": [
    {
      "src": "server.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "prisma/**",
        "excludeFiles": "src/**",
        "nodeVersion": "20.x"
      }
    },
    {
      "src": "dist/**",
      "use": "@vercel/static-build"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/index.html"
    }
  ]
}
